{
  "title": "PgBouncer (Single DB)",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [

    {
      "type": "stat",
      "title": "PgBouncer Up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "pgbouncer_up" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Active Clients",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(pgbouncer_pools_client_active_connections)" }]
    },
    {
      "type": "stat",
      "title": "Waiting Clients",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(pgbouncer_pools_client_waiting_connections)" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Pool Utilization %",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "100 * sum(pgbouncer_pools_client_active_connections) / sum(pgbouncer_databases_pool_size)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "QPS",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "rate(pgbouncer_stats_totals_queries_pooled_total[1m])"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Client Connections",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(pgbouncer_pools_client_active_connections)",
          "legendFormat": "active"
        },
        {
          "expr": "sum(pgbouncer_pools_client_waiting_connections)",
          "legendFormat": "waiting"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Server Connections",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(pgbouncer_pools_server_active_connections)",
          "legendFormat": "active"
        },
        {
          "expr": "sum(pgbouncer_pools_server_idle_connections)",
          "legendFormat": "idle"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Max Wait Time (s)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "max(pgbouncer_pools_client_maxwait_seconds)",
          "legendFormat": "max wait"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Client Wait Time Rate",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(pgbouncer_stats_totals_client_wait_seconds_total[1m])",
          "legendFormat": "wait/sec"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Throughput (QPS / TPS)",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pgbouncer_stats_totals_queries_pooled_total[1m])",
          "legendFormat": "QPS"
        },
        {
          "expr": "rate(pgbouncer_stats_totals_sql_transactions_pooled_total[1m])",
          "legendFormat": "TPS"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Throughput",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pgbouncer_stats_totals_received_bytes_total[1m])",
          "legendFormat": "in"
        },
        {
          "expr": "rate(pgbouncer_stats_totals_sent_bytes_total[1m])",
          "legendFormat": "out"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },

    {
      "type": "timeseries",
      "title": "Capacity (Clients / Servers)",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "pgbouncer_used_clients",
          "legendFormat": "used clients"
        },
        {
          "expr": "pgbouncer_free_clients",
          "legendFormat": "free clients"
        },
        {
          "expr": "pgbouncer_used_servers",
          "legendFormat": "used servers"
        },
        {
          "expr": "pgbouncer_free_servers",
          "legendFormat": "free servers"
        }
      ]
    }

  ]
}